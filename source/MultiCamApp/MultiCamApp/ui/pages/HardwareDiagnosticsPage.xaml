<UserControl x:Class="MultiCamApp.Ui.Pages.HardwareDiagnosticsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}">
    <UserControl.Resources>
        <Style x:Key="HardwareActionButton" TargetType="Button" BasedOn="{StaticResource PanelButtonBase}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style x:Key="HardwarePrimaryActionButton" TargetType="Button" BasedOn="{StaticResource HardwareActionButton}">
            <Setter Property="Background" Value="{StaticResource PreviewButtonBgBrush}"/>
            <Setter Property="BorderBrush" Value="#1D4ED8"/>
        </Style>
        <Style x:Key="HardwareSecondaryActionButton" TargetType="Button" BasedOn="{StaticResource HardwareActionButton}">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
            <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
        </Style>
        <Style x:Key="HardwareSummaryPanel" TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinWidth" Value="240"/>
            <Setter Property="MinHeight" Value="132"/>
        </Style>
        <Style x:Key="HardwarePanelTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentVideoBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="HardwarePanelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="HardwareExpander" TargetType="Expander">
            <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="HardwareReportPanel" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="HardwareReportTextBox" TargetType="TextBox" BasedOn="{StaticResource LogTextBoxStyle}">
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}"/>
            <Setter Property="Background" Value="#0B1220"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock x:Name="PageTitleText" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource AppForegroundBrush}" Margin="0,0,0,6"/>
                <TextBlock x:Name="PageDescriptionText"
                           TextWrapping="Wrap" Foreground="{StaticResource AppSecondaryTextBrush}"/>
                <Grid Margin="0,12,0,0" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="RunScanButton" MinWidth="150"
                            Grid.Column="0" Style="{StaticResource HardwarePrimaryActionButton}" Click="RunScanButton_Click"/>
                    <Button x:Name="OpenLogsButton" MinWidth="130"
                            Grid.Column="1" Style="{StaticResource HardwareSecondaryActionButton}" Click="OpenLogsButton_Click"/>
                    <Button x:Name="CopySummaryButton" MinWidth="180" Margin="0"
                            Grid.Column="2" Style="{StaticResource HardwareSecondaryActionButton}" Click="CopySummaryButton_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock x:Name="SummaryTitleText" FontWeight="SemiBold" FontSize="15"
                                   Foreground="{StaticResource AccentVideoBrush}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="LastScanText"
                                   Foreground="{StaticResource AppSecondaryTextBrush}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="RecommendedPresetText"
                                   TextWrapping="Wrap" Foreground="{StaticResource AccentVideoBrush}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="StatusText"
                                   TextWrapping="Wrap" Foreground="{StaticResource AppSecondaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource HardwareSummaryPanel}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock x:Name="SystemCardTitleText" Style="{StaticResource HardwarePanelTitle}"/>
                            <TextBlock x:Name="SystemCardText" Style="{StaticResource HardwarePanelText}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource HardwareSummaryPanel}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock x:Name="CameraDevicesCardTitleText" Style="{StaticResource HardwarePanelTitle}"/>
                            <TextBlock x:Name="CameraDevicesCardText" Style="{StaticResource HardwarePanelText}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource HardwareSummaryPanel}">
                        <StackPanel>
                            <TextBlock x:Name="UsbStatusCardTitleText" Style="{StaticResource HardwarePanelTitle}"/>
                            <TextBlock x:Name="UsbStatusCardText" Style="{StaticResource HardwarePanelText}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <Border Style="{StaticResource HardwareReportPanel}">
                            <Expander x:Name="SystemReportExpander" Style="{StaticResource HardwareExpander}" IsExpanded="False">
                            <TextBox x:Name="SystemSummaryBox" MinHeight="150" IsReadOnly="True"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Style="{StaticResource HardwareReportTextBox}"/>
                            </Expander>
                        </Border>
                        <Border Style="{StaticResource HardwareReportPanel}">
                            <Expander x:Name="CameraReportExpander" Style="{StaticResource HardwareExpander}" IsExpanded="False">
                            <TextBox x:Name="CameraSummaryBox" MinHeight="180" IsReadOnly="True"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Style="{StaticResource HardwareReportTextBox}"/>
                            </Expander>
                        </Border>
                        <Border Style="{StaticResource HardwareReportPanel}" Margin="0">
                            <Expander x:Name="UsbReportExpander" Style="{StaticResource HardwareExpander}" IsExpanded="False">
                            <TextBox x:Name="UsbSummaryBox" MinHeight="140" IsReadOnly="True"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Style="{StaticResource HardwareReportTextBox}"/>
                            </Expander>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
