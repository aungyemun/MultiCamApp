<UserControl x:Class="MultiCamApp.Ui.VideoEngineV2TestPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Visible">
    <!--
    VideoEngineV2 developer / test panel.
    Add this to a layout only in developer builds.
    Set Visibility="Visible" to show.
    All labels read from code-behind; no data binding required.
    -->
    <Border Background="{StaticResource HeaderBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrushMain}"
            BorderThickness="1" CornerRadius="4" Padding="12,10">
        <StackPanel>

            <!-- Title row -->
            <TextBlock Style="{StaticResource BodyText}"
                       FontWeight="SemiBold" Margin="0,0,0,6"
                       Text="VideoEngineV2 — Developer Mode"/>

            <!-- Enable flags -->
            <CheckBox x:Name="EnabledCheckBox"
                      Content="Enable VideoEngineV2"
                      Checked="EnabledCheckBox_Checked"
                      Unchecked="EnabledCheckBox_Unchecked"
                      Margin="0,2"/>

            <CheckBox x:Name="PreviewTestCheckBox"
                      Content="Allow cam1 preview test"
                      Checked="PreviewTestCheckBox_Checked"
                      Unchecked="PreviewTestCheckBox_Unchecked"
                      Margin="0,2"/>

            <CheckBox x:Name="RecordingTestCheckBox"
                      Content="Allow cam1 recording test (H.264)"
                      Checked="RecordingTestCheckBox_Checked"
                      Unchecked="RecordingTestCheckBox_Unchecked"
                      Margin="0,2"/>

            <Separator Margin="0,6"/>

            <!-- Status grid -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource BodyText}" Text="Backend:" Opacity="0.6"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="BackendLabel" Style="{StaticResource BodyText}" Text="Legacy"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource BodyText}" Text="Renderer:" Opacity="0.6"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RendererLabel" Style="{StaticResource BodyText}" Text="—"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource BodyText}" Text="Encoder:" Opacity="0.6"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="EncoderLabel" Style="{StaticResource BodyText}" Text="—"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource BodyText}" Text="HW Encoder:" Opacity="0.6"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="HwEncoderLabel" Style="{StaticResource BodyText}" Text="—"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource BodyText}" Text="Resolution:" Opacity="0.6"/>
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="ResolutionLabel" Style="{StaticResource BodyText}" Text="—"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource BodyText}" Text="Live FPS:" Opacity="0.6"/>
                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="LiveFpsLabel" Style="{StaticResource BodyText}" Text="—"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource BodyText}" Text="Frames:" Opacity="0.6"/>
                <TextBlock Grid.Row="6" Grid.Column="1" x:Name="FramesLabel" Style="{StaticResource BodyText}" Text="—"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource BodyText}" Text="Shutter:" Opacity="0.6"/>
                <TextBlock Grid.Row="7" Grid.Column="1" x:Name="ShutterLabel" Style="{StaticResource BodyText}" Text="—"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource BodyText}" Text="Camera status:" Opacity="0.6"/>
                <TextBlock Grid.Row="8" Grid.Column="1" x:Name="CameraStatusLabel" Style="{StaticResource BodyText}" Text="—"/>

                <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource BodyText}" Text="Format kind:" Opacity="0.6"/>
                <TextBlock Grid.Row="9" Grid.Column="1" x:Name="FormatKindLabel" Style="{StaticResource BodyText}" Text="—"/>

                <TextBlock Grid.Row="10" Grid.Column="0" Style="{StaticResource BodyText}" Text="D3D11 / MF:" Opacity="0.6"/>
                <TextBlock Grid.Row="10" Grid.Column="1" x:Name="CapabilityLabel" Style="{StaticResource BodyText}" Text="—"/>

                <TextBlock Grid.Row="11" Grid.Column="0" Style="{StaticResource BodyText}" Text="USB / PnP:" Opacity="0.6"/>
                <TextBlock Grid.Row="11" Grid.Column="1" x:Name="UsbPnpLabel" Style="{StaticResource BodyText}"
                           Text="—" TextWrapping="Wrap"/>
            </Grid>

            <!-- Fallback warning -->
            <TextBlock x:Name="FallbackWarningLabel"
                       Style="{StaticResource BodyText}"
                       Foreground="#FFB347"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"
                       Margin="0,6,0,0"/>

            <!-- Studio Effects warning -->
            <TextBlock x:Name="StudioEffectsWarningLabel"
                       Style="{StaticResource BodyText}"
                       Foreground="#FFB347"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"
                       Margin="0,4,0,0"/>

            <!-- Error label (pipeline failures, camera conflicts) -->
            <TextBlock x:Name="ErrorLabel"
                       Style="{StaticResource BodyText}"
                       Foreground="#FF6B6B"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"
                       Margin="0,4,0,0"/>

            <!-- V2 cam1 live preview -->
            <Border Margin="0,8,0,0" Height="180"
                    Background="Black" CornerRadius="2"
                    Visibility="{Binding Visibility, ElementName=PreviewImageHost}">
                <Grid>
                    <Image x:Name="V2PreviewImage"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="LowQuality"/>
                    <TextBlock x:Name="PreviewPlaceholderLabel"
                               Text="V2 preview not started"
                               Style="{StaticResource BodyText}"
                               Foreground="#888"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <FrameworkElement x:Name="PreviewImageHost" Visibility="Collapsed"/>

        </StackPanel>
    </Border>
</UserControl>
