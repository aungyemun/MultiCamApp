<Window x:Class="MultiCamApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:MultiCamApp.Ui"
        xmlns:pages="clr-namespace:MultiCamApp.Ui.Pages"
        Title="MultiCamApp"
        MinWidth="1024" MinHeight="640"
        Height="800" Width="1280"
        Background="{StaticResource AppBackgroundBrush}"
        SizeChanged="Window_SizeChanged"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="ReadableDisabledStopPreviewButtonStyle" TargetType="Button" BasedOn="{StaticResource StopPreviewButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource DisabledControlBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource DisabledControlTextBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource DisabledControlBorderBrush}"/>
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ReadableDisabledRecordStartButtonStyle" TargetType="Button" BasedOn="{StaticResource RecordStartButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource DisabledControlBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource DisabledControlTextBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource DisabledControlBorderBrush}"/>
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ReadableDisabledRecordStopButtonStyle" TargetType="Button" BasedOn="{StaticResource RecordStopButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource DisabledControlBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource DisabledControlTextBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource DisabledControlBorderBrush}"/>
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <ui:HeaderBar x:Name="HeaderBarControl" DockPanel.Dock="Top"/>

        <Border DockPanel.Dock="Bottom" Background="{StaticResource FooterBackgroundBrush}"
                BorderThickness="0" Padding="10,8">
            <TextBlock x:Name="FooterText"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       TextWrapping="Wrap" FontSize="12"
                       Foreground="{StaticResource AppForegroundBrush}"/>
        </Border>

        <Grid Background="{StaticResource AppBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <ui:MainNavigation x:Name="MainNavControl" Grid.Row="0"/>

            <Grid x:Name="RecordingPagePanel" Grid.Row="1" Margin="8,6,8,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="375" MinWidth="360" MaxWidth="390"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*" MinWidth="420"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrushMain}" BorderThickness="1"
                        CornerRadius="6" Padding="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="10" MinWidth="320">

                            <Button x:Name="RefreshDevicesBtn" Margin="0,0,0,9"
                                    Style="{StaticResource NeutralButtonStyle}"
                                    Click="RefreshDevicesBtn_Click"/>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock x:Name="LayoutSectionTitle" Style="{StaticResource SectionTitleLayout}"/>
                                    <StackPanel x:Name="LayoutPanel"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel x:Name="DeviceSectionPanel">
                                    <TextBlock x:Name="SelectionSectionTitle" Style="{StaticResource SectionTitleSelection}"/>
                                    <StackPanel x:Name="Cam1Block" Margin="0,0,0,10">
                                        <TextBlock x:Name="Cam1Label" Style="{StaticResource BodyText}"
                                                   Foreground="{StaticResource AppForegroundBrush}" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="Cam1Box" Style="{StaticResource InputComboBoxStyle}"
                                                  SelectionChanged="DeviceBox_SelectionChanged"/>
                                    </StackPanel>
                                    <StackPanel x:Name="Cam2Block" Margin="0,0,0,10" Visibility="Collapsed">
                                        <TextBlock x:Name="Cam2Label" Style="{StaticResource BodyText}"
                                                   Foreground="{StaticResource AppForegroundBrush}" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="Cam2Box" Style="{StaticResource InputComboBoxStyle}"
                                                  SelectionChanged="DeviceBox_SelectionChanged"/>
                                    </StackPanel>
                                    <StackPanel x:Name="Cam3Block" Margin="0,0,0,10" Visibility="Collapsed">
                                        <TextBlock x:Name="Cam3Label" Style="{StaticResource BodyText}"
                                                   Foreground="{StaticResource AppForegroundBrush}" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="Cam3Box" Style="{StaticResource InputComboBoxStyle}"
                                                  SelectionChanged="DeviceBox_SelectionChanged"/>
                                    </StackPanel>
                                    <StackPanel x:Name="Cam4Block" Visibility="Collapsed">
                                        <TextBlock x:Name="Cam4Label" Style="{StaticResource BodyText}"
                                                   Foreground="{StaticResource AppForegroundBrush}" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="Cam4Box" Style="{StaticResource InputComboBoxStyle}"
                                                  SelectionChanged="DeviceBox_SelectionChanged"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock x:Name="VideoSectionTitle" Style="{StaticResource SectionTitleVideo}"/>
                                    <TextBlock x:Name="ResolutionLabel" Style="{StaticResource BodyText}"
                                               Foreground="{StaticResource AppForegroundBrush}" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="ResolutionBox" Style="{StaticResource InputComboBoxStyle}"
                                              Margin="0,0,0,10"
                                              SelectionChanged="VideoSettings_Changed"/>
                                    <TextBlock x:Name="FpsLabel" Style="{StaticResource BodyText}"
                                               Foreground="{StaticResource AppForegroundBrush}" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="FpsBox" Style="{StaticResource InputComboBoxStyle}"
                                              SelectionChanged="VideoSettings_Changed"/>
                                    <CheckBox x:Name="HighStabilityRecordingModeCheckBox"
                                              Margin="0,8,0,0"
                                              Foreground="{StaticResource AppForegroundBrush}"
                                              FontWeight="SemiBold"
                                              Content="High-Stability Recording Mode"
                                              IsChecked="True"
                                              Click="HighStabilityRecordingModeCheckBox_Click"
                                              ToolTip="Recommended for clean timing, stable FPS, and original-frame recording. Enables adaptive preview FPS and elevated writer thread priority."/>
                                    <TextBlock Style="{StaticResource BodyText}"
                                               FontSize="12" Margin="0,4,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource AppSecondaryTextBrush}"
                                               Text="Recommended for clean timing, stable FPS, and original-frame recording."/>
                                    <TextBlock Text="Preview FPS during recording"
                                               Style="{StaticResource BodyText}"
                                               Foreground="{StaticResource AppForegroundBrush}"
                                               Margin="0,8,0,4"/>
                                    <ComboBox x:Name="RecordingPreviewFpsModeBox"
                                              Style="{StaticResource InputComboBoxStyle}"
                                              Margin="0,0,0,4"
                                              SelectionChanged="RecordingPreviewFpsModeBox_SelectionChanged">
                                        <ComboBoxItem Content="Smooth (higher preview FPS)" Tag="Smooth"/>
                                        <ComboBoxItem Content="Balanced (recommended)" Tag="Balanced" IsSelected="True"/>
                                        <ComboBoxItem Content="Maximum Stability (lower preview FPS)" Tag="MaxStability"/>
                                    </ComboBox>
                                    <TextBlock Style="{StaticResource BodyText}"
                                               FontSize="12" Margin="0,2,0,8"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource AppSecondaryTextBrush}"
                                               Text="Balanced: 20/15/12/10 fps for 1/2/3/4 cameras. Preview stays on during recording for focus and brightness monitoring."/>
                                    <Expander x:Name="AdvancedCameraControlsExpander"
                                              Header="Advanced Camera Controls"
                                              Margin="0,10,0,0"
                                              Foreground="{StaticResource AppForegroundBrush}"
                                              IsExpanded="False">
                                        <Border BorderBrush="{StaticResource BorderBrushMain}"
                                                BorderThickness="1"
                                                CornerRadius="5"
                                                Padding="10"
                                                Margin="0,6,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Camera Target" Style="{StaticResource BodyText}"
                                                           Foreground="{StaticResource AppForegroundBrush}"
                                                           FontWeight="SemiBold" Margin="0,0,0,2"/>
                                                <TextBlock Text="Adjust settings for:"
                                                           Style="{StaticResource BodyText}"
                                                           Foreground="{StaticResource AppSecondaryTextBrush}"
                                                           FontSize="12" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="FocusCameraTargetBox"
                                                          Style="{StaticResource InputComboBoxStyle}"
                                                          Margin="0,0,0,8"
                                                          SelectionChanged="FocusCameraTargetBox_SelectionChanged"/>
                                                <TextBlock Style="{StaticResource BodyText}"
                                                           FontSize="12" Margin="0,0,0,8"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource AppSecondaryTextBrush}"
                                                           Text="Focus and exposure settings apply to the selected camera only.&#x0a;Each camera can have independent values."/>
                                                <CheckBox x:Name="AdvancedAutoFocusCheckBox"
                                                          Margin="0,8,0,0"
                                                          Foreground="{StaticResource AppSecondaryTextBrush}"
                                                          Content="Auto focus"
                                                          ToolTip="Some cameras ignore software autofocus commands. If focus still changes, disable autofocus in the camera body or vendor software."
                                                          Click="AdvancedAutoFocusCheckBox_Click"/>
                                                <TextBlock Text="Manual focus value" Style="{StaticResource BodyText}"
                                                           Foreground="{StaticResource AppForegroundBrush}" Margin="0,8,0,4"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="70"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Slider x:Name="ManualFocusSlider"
                                                            Grid.Column="0"
                                                            Minimum="0"
                                                            Maximum="255"
                                                            TickFrequency="1"
                                                            IsSnapToTickEnabled="False"
                                                            ValueChanged="ManualFocusSlider_ValueChanged"/>
                                                    <TextBox x:Name="ManualFocusValueBox"
                                                             Grid.Column="1"
                                                             Margin="8,0,0,0"
                                                             Style="{StaticResource InputTextBoxStyle}"
                                                             TextChanged="ManualFocusValueBox_TextChanged"/>
                                                </Grid>
                                                <TextBlock x:Name="ManualFocusAvailabilityText"
                                                           Style="{StaticResource BodyText}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Margin="0,6,0,0"
                                                           Foreground="{StaticResource AppSecondaryTextBrush}"/>
                                                <CheckBox x:Name="ReapplyFocusBeforeRecordingCheckBox"
                                                          Margin="0,8,0,0"
                                                          Foreground="{StaticResource AppSecondaryTextBrush}"
                                                          Content="Re-apply focus before recording"
                                                          IsChecked="True"
                                                          Click="ReapplyFocusBeforeRecordingCheckBox_Click"/>
                                                <Button x:Name="ApplyFocusSettingButton"
                                                        Content="Apply Focus Setting"
                                                        Margin="0,10,0,0"
                                                        Style="{StaticResource NeutralButtonStyle}"
                                                        Click="ApplyFocusSettingButton_Click"/>

                                                <Separator Margin="0,12,0,8" Background="{StaticResource BorderBrushMain}"/>
                                                <TextBlock Text="Exposure Controls"
                                                           Style="{StaticResource BodyText}"
                                                           Foreground="{StaticResource AppForegroundBrush}"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,4"/>
                                                <CheckBox x:Name="AdvancedAutoExposureCheckBox"
                                                          Margin="0,4,0,0"
                                                          Foreground="{StaticResource AppSecondaryTextBrush}"
                                                          Content="Auto exposure"
                                                          IsChecked="False"
                                                          ToolTip="Request auto exposure from the camera. Uncheck to apply a fixed manual exposure value."
                                                          Click="AdvancedAutoExposureCheckBox_Click"/>
                                                <TextBlock Text="Manual exposure value (0–255)"
                                                           Style="{StaticResource BodyText}"
                                                           Foreground="{StaticResource AppForegroundBrush}"
                                                           Margin="0,8,0,4"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="70"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Slider x:Name="ManualExposureSlider"
                                                            Grid.Column="0"
                                                            Minimum="0"
                                                            Maximum="255"
                                                            TickFrequency="1"
                                                            IsSnapToTickEnabled="False"
                                                            ValueChanged="ManualExposureSlider_ValueChanged"/>
                                                    <TextBox x:Name="ManualExposureValueBox"
                                                             Grid.Column="1"
                                                             Margin="8,0,0,0"
                                                             Style="{StaticResource InputTextBoxStyle}"
                                                             TextChanged="ManualExposureValueBox_TextChanged"/>
                                                </Grid>
                                                <TextBlock Style="{StaticResource BodyText}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Margin="0,6,0,0"
                                                           Foreground="{StaticResource AppSecondaryTextBrush}"
                                                           Text="Manual exposure is best-effort. Some cameras may ignore it.&#x0a;For motion studies, use bright even lighting and fixed exposure."/>
                                                <CheckBox x:Name="DisableLowLightCompensationCheckBox"
                                                          Margin="0,8,0,0"
                                                          Foreground="{StaticResource AppSecondaryTextBrush}"
                                                          Content="Disable low-light compensation"
                                                          IsChecked="True"
                                                          ToolTip="Low-light compensation may increase motion blur.&#x0a;Turn it off when recording fast movement."
                                                          Click="DisableLowLightCompensationCheckBox_Click"/>
                                                <TextBlock Style="{StaticResource BodyText}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"
                                                           Foreground="{StaticResource AppSecondaryTextBrush}"
                                                           Text="Low-light compensation may increase motion blur.&#x0a;Turn it off when recording fast movement."/>
                                                <CheckBox x:Name="ReapplyExposureBeforeRecordingCheckBox"
                                                          Margin="0,8,0,0"
                                                          Foreground="{StaticResource AppSecondaryTextBrush}"
                                                          Content="Re-apply exposure at recording start"
                                                          IsChecked="True"
                                                          Click="ReapplyExposureBeforeRecordingCheckBox_Click"/>
                                                <Button x:Name="ApplyExposureSettingButton"
                                                        Content="Apply Exposure Setting"
                                                        Margin="0,10,0,0"
                                                        Style="{StaticResource NeutralButtonStyle}"
                                                        Click="ApplyExposureSettingButton_Click"/>
                                                <TextBlock x:Name="ExposureStatusText"
                                                           Style="{StaticResource BodyText}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Margin="0,6,0,0"
                                                           Foreground="{StaticResource AppSecondaryTextBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </Expander>
                                    <TextBlock x:Name="VideoSettingsHint" Style="{StaticResource BodyText}"
                                               FontSize="12" Margin="0,8,0,0"
                                               TextWrapping="Wrap"/>
                                    <TextBlock x:Name="ConstantFrameCountInfoText" Style="{StaticResource BodyText}"
                                               FontSize="12" Margin="0,8,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource AppSecondaryTextBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock x:Name="OutputSectionTitle" Style="{StaticResource SectionTitleOutput}"/>
                                    <TextBlock x:Name="OutputLabel" Style="{StaticResource BodyText}"
                                               Foreground="{StaticResource AppForegroundBrush}" Margin="0,0,0,6"/>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="OutputBox" Grid.Column="0" IsReadOnly="True"
                                                 Style="{StaticResource InputTextBoxStyle}"/>
                                        <Button x:Name="BrowseBtn" Grid.Column="1"
                                                MinWidth="84" Margin="10,0,0,0"
                                                Style="{StaticResource NeutralButtonStyle}"
                                                Click="BrowseBtn_Click"/>
                                    </Grid>
                                    <TextBlock x:Name="SessionLabel" Style="{StaticResource BodyText}"
                                               Foreground="{StaticResource AppForegroundBrush}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="SessionBox" Style="{StaticResource InputTextBoxStyle}"
                                             TextChanged="SessionBox_TextChanged"/>
                                    <TextBlock x:Name="SessionFolderPreviewLabel" Style="{StaticResource BodyText}"
                                               FontSize="12" Margin="0,8,0,4" Opacity="0.85"/>
                                    <TextBlock x:Name="SessionFolderPreviewValue" Style="{StaticResource BodyText}"
                                               FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"
                                               Foreground="{StaticResource AccentVideoBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCardStyle}">
                                <StackPanel>
                                    <TextBlock x:Name="ControlsSectionTitle" Style="{StaticResource SectionTitleControls}"/>
                                    <TextBlock x:Name="PreviewControlsLabel" Style="{StaticResource BodyText}"
                                               Foreground="{StaticResource AppForegroundBrush}" Margin="0,0,0,6"/>
                                    <Button x:Name="StartPreviewBtn" Style="{StaticResource PreviewButtonStyle}"
                                            Click="StartPreviewBtn_Click"/>
                                    <Button x:Name="StopPreviewBtn" Style="{StaticResource ReadableDisabledStopPreviewButtonStyle}"
                                            Click="StopPreviewBtn_Click"/>
                                    <Border Height="14" Background="Transparent"/>
                                    <TextBlock x:Name="RecordingControlsLabel" Style="{StaticResource BodyText}"
                                               Foreground="{StaticResource AppForegroundBrush}" Margin="0,0,0,6"/>
                                    <Button x:Name="StartRecordBtn" Style="{StaticResource ReadableDisabledRecordStartButtonStyle}"
                                            Click="StartRecordBtn_Click"/>
                                    <Button x:Name="StopRecordBtn" Style="{StaticResource ReadableDisabledRecordStopButtonStyle}"
                                            Margin="0" Click="StopRecordBtn_Click"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource StatusCardStyle}">
                                <StackPanel>
                                    <TextBlock x:Name="StatusSectionTitle" Style="{StaticResource SectionTitleStatus}"/>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{StaticResource ActiveDotBrush}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="StatusLabel" Style="{StaticResource StatusLabelText}"/>
                                            <TextBlock x:Name="StatusValue" Style="{StaticResource StatusValueText}" Margin="0,0,0,6"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock x:Name="ElapsedLabel" Style="{StaticResource StatusLabelText}"/>
                                    <TextBlock x:Name="ElapsedValue" Style="{StaticResource StatusValueText}"/>
                                    <TextBlock x:Name="SessionTimeLabel" Style="{StaticResource StatusLabelText}"/>
                                    <TextBlock x:Name="SessionTimeValue" Style="{StaticResource StatusValueText}"/>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse x:Name="PreviewDot" Width="8" Height="8" Fill="{StaticResource ActiveDotBrush}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="PreviewStatusLabel" Style="{StaticResource StatusLabelText}"/>
                                            <TextBlock x:Name="PreviewStatusValue" Style="{StaticResource StatusValueText}" Margin="0,0,0,6"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock x:Name="CamerasLabel" Style="{StaticResource StatusLabelText}"/>
                                    <TextBlock x:Name="CamerasValue" Style="{StaticResource StatusValueText}" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="PreviewStartupStatusText" Style="{StaticResource BodyText}"
                                               FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"
                                               Foreground="{StaticResource AppSecondaryTextBrush}"/>
                                    <TextBlock x:Name="MultiCamUsbWarningText" Style="{StaticResource BodyText}"
                                               FontSize="12" TextWrapping="Wrap" Margin="0"
                                               Foreground="{StaticResource AccentVideoBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border Grid.Column="2" Background="{StaticResource PreviewCanvasBrush}"
                        BorderBrush="{StaticResource BorderBrushMain}" BorderThickness="1"
                        CornerRadius="6" Padding="6" MinHeight="200">
                    <Grid x:Name="LayoutHost" Background="{StaticResource PreviewCanvasBrush}" MinHeight="200"/>
                </Border>
            </Grid>

            <pages:VideoVerificationPage x:Name="VerificationPage" Grid.Row="1"
                                         Visibility="Collapsed"/>
            <pages:HardwareDiagnosticsPage x:Name="HardwareDiagnosticsPage" Grid.Row="1"
                                           Visibility="Collapsed"/>
        </Grid>
    </DockPanel>
</Window>
