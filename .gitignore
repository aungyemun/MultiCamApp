# ============================================================
# MultiCamApp — project-specific ignores
# ============================================================

# Generated release outputs
dist/
.build/
release_audit/

# Local toolchains (large, machine-specific)
tools/
data/

# Logs (runtime and dev)
logs/
dist/logs/

# Developer/agent scratch folders
.agents/
.claude/

# Installer outputs (generated by build_release.bat)
installer/Setup.exe
installer/*_Setup.exe
installer/installer.zip
installer/build_release_summary.txt
installer/vc_redist.x64.exe

# Large runtime binaries not tracked in source
runtime/ffmpeg/ffmpeg.exe
runtime/ffmpeg/ffprobe.exe
runtime/vc_runtime/

# Video files
Videos/
*.mp4
*.avi
*.mov
*.mkv
*.webm
*.m4v
*.wmv

# Session/conversation logs
*.jsonl

# Root dev launcher (generated by build_release.ps1)
/MultiCamApp.exe
/MultiCamApp.*
/*.dll

# Lock files
STABLE_CORE_V1.lock

# ============================================================
# Visual Studio / .NET standard ignores
# ============================================================

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.env

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
**/[Bb]in/
**/[Oo]bj/
[Oo]ut/
bld/

# Visual Studio cache
.vs/
.vshistory/
**/.localhistory/
**/.ionide/

# MSTest / test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
*.coveragexml

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# Python
**/__pycache__/
*.pyc

# Build logs / artifacts
*.binlog
MSBuild_Logs/
*.ilk
*.pdb
*.ipdb
*.tmp
*_wpftmp.csproj
*.log

# NOTE: *.json is NOT globally ignored — config/ and localization/ JSON files
# are required source files. Only specific generated JSON patterns are excluded
# (e.g. coverage*.json, project.lock.json).
coverage*.json
project.lock.json
project.fragment.lock.json

# ============================================================
# Diagnostics — machine-specific scan outputs (do not commit)
# docs/, scripts/diagnostics/, and tools/CameraCapabilityScanner/ ARE tracked.
# ============================================================
diagnostics/*.txt
diagnostics/*.json
diagnostics/*.csv
diagnostics/*.log
