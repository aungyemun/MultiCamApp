<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Color tokens -->
    <Color x:Key="Color.AppBackground">#0B0F14</Color>
    <Color x:Key="Color.PanelBackground">#111827</Color>
    <Color x:Key="Color.CardBackground">#0F172A</Color>
    <Color x:Key="Color.HeaderBackground">#05070A</Color>
    <Color x:Key="Color.FooterBackground">#05070A</Color>
    <Color x:Key="Color.BorderMain">#334155</Color>
    <Color x:Key="Color.TextPrimary">#F9FAFB</Color>
    <Color x:Key="Color.TextSecondary">#CBD5E1</Color>
    <Color x:Key="Color.TextMuted">#94A3B8</Color>
    <Color x:Key="Color.TextDisabled">#64748B</Color>
    <Color x:Key="Color.DisabledBackground">#2B3240</Color>
    <Color x:Key="Color.DisabledText">#7A8494</Color>
    <Color x:Key="Color.DisabledBorder">#3A4352</Color>
    <Color x:Key="Color.InputBackground">#FFFFFF</Color>
    <Color x:Key="Color.InputText">#111827</Color>
    <Color x:Key="Color.PreviewCanvas">#080A0C</Color>
    <Color x:Key="Color.ActiveDot">#22C55E</Color>

    <Color x:Key="Color.Accent.Cam1">#3B82F6</Color>
    <Color x:Key="Color.Accent.Cam2">#D946EF</Color>
    <Color x:Key="Color.Accent.Cam3">#F59E0B</Color>
    <Color x:Key="Color.Accent.Cam4">#06B6D4</Color>
    <Color x:Key="Color.Accent.Layout">#3B82F6</Color>
    <Color x:Key="Color.Accent.Selection">#22C55E</Color>
    <Color x:Key="Color.Accent.Output">#F59E0B</Color>
    <Color x:Key="Color.Accent.Controls">#A855F7</Color>
    <Color x:Key="Color.Accent.Status">#EAB308</Color>
    <Color x:Key="Color.Accent.Video">#38BDF8</Color>

    <Color x:Key="Color.Btn.StartPreview">#2563EB</Color>
    <Color x:Key="Color.Btn.StopPreview">#374151</Color>
    <Color x:Key="Color.Btn.StartRecord">#16A34A</Color>
    <Color x:Key="Color.Btn.StopRecord">#DC2626</Color>
    <Color x:Key="Color.Status.Recording">#22C55E</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource Color.AppBackground}"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource Color.PanelBackground}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource Color.CardBackground}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource Color.HeaderBackground}"/>
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="{StaticResource Color.FooterBackground}"/>
    <SolidColorBrush x:Key="BorderBrushMain" Color="{StaticResource Color.BorderMain}"/>
    <SolidColorBrush x:Key="AppForegroundBrush" Color="{StaticResource Color.TextPrimary}"/>
    <SolidColorBrush x:Key="AppSecondaryTextBrush" Color="{StaticResource Color.TextSecondary}"/>
    <SolidColorBrush x:Key="AppMutedTextBrush" Color="{StaticResource Color.TextMuted}"/>
    <SolidColorBrush x:Key="DisabledFgBrush" Color="{StaticResource Color.TextDisabled}"/>
    <SolidColorBrush x:Key="DisabledControlBackgroundBrush" Color="{StaticResource Color.DisabledBackground}"/>
    <SolidColorBrush x:Key="DisabledControlTextBrush" Color="{StaticResource Color.DisabledText}"/>
    <SolidColorBrush x:Key="DisabledControlBorderBrush" Color="{StaticResource Color.DisabledBorder}"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource Color.InputBackground}"/>
    <SolidColorBrush x:Key="InputForegroundBrush" Color="{StaticResource Color.InputText}"/>
    <SolidColorBrush x:Key="PreviewCanvasBrush" Color="{StaticResource Color.PreviewCanvas}"/>
    <SolidColorBrush x:Key="ActiveDotBrush" Color="{StaticResource Color.ActiveDot}"/>
    <SolidColorBrush x:Key="AppControlBackgroundBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="FooterAccentLineBrush" Color="#A855F7"/>

    <SolidColorBrush x:Key="AccentCam1Brush" Color="{StaticResource Color.Accent.Cam1}"/>
    <SolidColorBrush x:Key="AccentCam2Brush" Color="{StaticResource Color.Accent.Cam2}"/>
    <SolidColorBrush x:Key="AccentCam3Brush" Color="{StaticResource Color.Accent.Cam3}"/>
    <SolidColorBrush x:Key="AccentCam4Brush" Color="{StaticResource Color.Accent.Cam4}"/>
    <SolidColorBrush x:Key="AccentLayoutBrush" Color="{StaticResource Color.Accent.Layout}"/>
    <SolidColorBrush x:Key="AccentSelectionBrush" Color="{StaticResource Color.Accent.Selection}"/>
    <SolidColorBrush x:Key="AccentOutputBrush" Color="{StaticResource Color.Accent.Output}"/>
    <SolidColorBrush x:Key="AccentControlsBrush" Color="{StaticResource Color.Accent.Controls}"/>
    <SolidColorBrush x:Key="AccentStatusBrush" Color="{StaticResource Color.Accent.Status}"/>
    <SolidColorBrush x:Key="AccentVideoBrush" Color="{StaticResource Color.Accent.Video}"/>
    <SolidColorBrush x:Key="StatusRecordingBrush" Color="{StaticResource Color.Status.Recording}"/>

    <SolidColorBrush x:Key="PreviewButtonBgBrush" Color="{StaticResource Color.Btn.StartPreview}"/>
    <SolidColorBrush x:Key="StopPreviewButtonBgBrush" Color="{StaticResource Color.Btn.StopPreview}"/>
    <SolidColorBrush x:Key="RecordButtonBgBrush" Color="{StaticResource Color.Btn.StartRecord}"/>
    <SolidColorBrush x:Key="StopRecordButtonBgBrush" Color="{StaticResource Color.Btn.StopRecord}"/>

    <!-- Typography -->
    <Style x:Key="AppTitleText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="HeaderVersionText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="HeaderSubtitleText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AppSecondaryTextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AppSecondaryTextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="LineHeight" Value="18"/>
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
    </Style>

    <Style x:Key="SectionTitleText" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="SectionTitleLayout" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleText}">
        <Setter Property="Foreground" Value="{StaticResource AccentVideoBrush}"/>
    </Style>
    <Style x:Key="SectionTitleSelection" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleText}">
        <Setter Property="Foreground" Value="{StaticResource AccentVideoBrush}"/>
    </Style>
    <Style x:Key="SectionTitleVideo" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleText}">
        <Setter Property="Foreground" Value="{StaticResource AccentVideoBrush}"/>
    </Style>
    <Style x:Key="SectionTitleOutput" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleText}">
        <Setter Property="Foreground" Value="{StaticResource AccentVideoBrush}"/>
    </Style>
    <Style x:Key="SectionTitleControls" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleText}">
        <Setter Property="Foreground" Value="{StaticResource AccentVideoBrush}"/>
    </Style>
    <Style x:Key="SectionTitleStatus" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleText}">
        <Setter Property="Foreground" Value="{StaticResource AccentVideoBrush}"/>
    </Style>

    <Style x:Key="MainNavText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="StatusLabelText" TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
        <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>

    <Style x:Key="StatusValueText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- Cards -->
    <Style x:Key="SectionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Margin" Value="0,0,0,9"/>
    </Style>

    <Style x:Key="StatusCardStyle" TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
        <Setter Property="Margin" Value="0"/>
    </Style>

    <!-- Inputs -->
    <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource InputForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="MinHeight" Value="34"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <TextBlock x:Name="watermark" Text="{TemplateBinding Tag}" Margin="10,0,0,0" 
                                   VerticalAlignment="Center" Foreground="{StaticResource AppMutedTextBrush}" 
                                   IsHitTestVisible="False" Visibility="Collapsed"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource DisabledControlBackgroundBrush}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource DisabledControlBorderBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource DisabledControlTextBrush}"/>
                            <Setter Property="Opacity" Value="1"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Text" Value=""/>
                                <Condition Property="IsFocused" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="watermark" Property="Visibility" Value="Visible"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource InputForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="MinHeight" Value="34"/>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{StaticResource DisabledControlBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource DisabledControlTextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource DisabledControlBorderBrush}"/>
                <Setter Property="Opacity" Value="1"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Buttons -->
    <Style x:Key="PanelButtonBase" TargetType="Button">
        <Setter Property="Height" Value="36"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.82"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.65"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource DisabledControlBackgroundBrush}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource DisabledControlBorderBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource DisabledControlTextBrush}"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                            <Setter Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PreviewButtonStyle" TargetType="Button" BasedOn="{StaticResource PanelButtonBase}">
        <Setter Property="Background" Value="{StaticResource PreviewButtonBgBrush}"/>
        <Setter Property="BorderBrush" Value="#1D4ED8"/>
    </Style>

    <Style x:Key="StopPreviewButtonStyle" TargetType="Button" BasedOn="{StaticResource PanelButtonBase}">
        <Setter Property="Background" Value="{StaticResource StopPreviewButtonBgBrush}"/>
        <Setter Property="BorderBrush" Value="#4B5563"/>
    </Style>

    <Style x:Key="RecordStartButtonStyle" TargetType="Button" BasedOn="{StaticResource PanelButtonBase}">
        <Setter Property="Background" Value="{StaticResource RecordButtonBgBrush}"/>
        <Setter Property="BorderBrush" Value="#15803D"/>
    </Style>

    <Style x:Key="RecordStopButtonStyle" TargetType="Button" BasedOn="{StaticResource PanelButtonBase}">
        <Setter Property="Background" Value="{StaticResource StopRecordButtonBgBrush}"/>
        <Setter Property="BorderBrush" Value="#B91C1C"/>
    </Style>

    <Style x:Key="NeutralButtonStyle" TargetType="Button" BasedOn="{StaticResource PanelButtonBase}">
        <Setter Property="Background" Value="#1E293B"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
    </Style>

    <Style x:Key="HeaderAboutButtonStyle" TargetType="Button" BasedOn="{StaticResource NeutralButtonStyle}">
        <Setter Property="Height" Value="32"/>
        <Setter Property="MinWidth" Value="72"/>
        <Setter Property="Margin" Value="8,0,0,0"/>
        <Setter Property="Padding" Value="12,4"/>
    </Style>

    <Style x:Key="VerifyButtonStyle" TargetType="Button" BasedOn="{StaticResource PanelButtonBase}">
        <Setter Property="Background" Value="#7C3AED"/>
        <Setter Property="BorderBrush" Value="#6D28D9"/>
    </Style>

    <SolidColorBrush x:Key="VerdictPassBrush" Color="#22C55E"/>
    <SolidColorBrush x:Key="VerdictWarningBrush" Color="#EAB308"/>
    <SolidColorBrush x:Key="VerdictFailBrush" Color="#DC2626"/>

    <Style x:Key="LogTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="#0F172A"/>
        <Setter Property="Foreground" Value="{StaticResource AppSecondaryTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="AcceptsReturn" Value="True"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
    </Style>

    <Style x:Key="NavTabButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource AppSecondaryTextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="4,8,16,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
    </Style>

    <Style x:Key="NavTabButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavTabButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentLayoutBrush}"/>
    </Style>

    <Style x:Key="LayoutRadioStyle" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="RowBackground" Value="{StaticResource CardBackgroundBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="#111827"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrushMain}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BorderBrushMain}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#1E293B"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="BorderThickness" Value="0"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#334155"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1F2937"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Trigger>
        </Style.Triggers>
    </Style>


    <!-- Dark ToolTip style — keeps tooltips readable in dark theme -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="#1E293B"/>
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="MaxWidth" Value="320"/>
    </Style>

    <!-- Env-lock action button — amber border signals a state-changing hardware action -->
    <Style x:Key="EnvLockButtonStyle" TargetType="Button" BasedOn="{StaticResource NeutralButtonStyle}">
        <Setter Property="BorderBrush" Value="#B45309"/>
        <Setter Property="Foreground" Value="#FDE68A"/>
    </Style>

    <!-- Compact Slider style tuned for dark panel backgrounds -->
    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource AccentVideoBrush}"/>
        <Setter Property="Background" Value="{StaticResource AppControlBackgroundBrush}"/>
        <Setter Property="MinHeight" Value="22"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Scrollbar — slim dark track -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="8"/>
    </Style>

</ResourceDictionary>
