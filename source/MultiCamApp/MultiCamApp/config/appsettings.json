{
  "appName": "MultiCamApp",
  "defaultLanguage": "en",
  "maxCameras": 4,
  "defaultOutputFolder": "Videos",
  "useSystemRecommendedResolution": true,
  "preferFps": 30,
  "preferredCaptureWidth": 1920,
  "preferredCaptureHeight": 1080,
  "forceFixedResolution": false,
  "enableHardwareAcceleration": true,
  "showHardwareInfoInUi": false,
  "enableResponsiveUi": true,
  "preservePreviewAspectRatio": true,
  "releaseCamerasOnStopPreview": true,
  "releaseCamerasOnAppClose": true,
  "pausePreviewOnMinimize": true,
  "allowRecordingWhileMinimizedOnlyIfUserStartedRecording": true,
  "hiddenRecordingAllowed": false,
  "privacyMode": true,
  "enableDiagnostics": true,
  "enableCrashLogs": true,
  "autoCreateSessionFolder": true,
  "maxPreviewFpsUi": 20,
  "autoFocusEnabled": false,
  "autoExposureEnabled": false,
  "disableLowLightCompensation": true,
  "reapplyExposureBeforeRecording": true,
  "previewEngine": "opencv",
  "recordingEngine": "opencv",
  "recordingHandoffDelayMs": 500,
  "preferredCameraPolicy": "default",
  "includeDisabledCameras": false,
  "useLowLagRecording": true,
  "recordingFileNameStyle": "camera_roll",
  "recordLimitHours": 3,
  "experimentMode": {
    "enabled": true,
    "defaultDurationSeconds": 660,
    "defaultFps": 30,
    "expectedFramesFormula": "durationSeconds * fps",
    "strictFrameValidation": true,
    "constantFrameCountMode": false,
    "allowConstantFrameCountMode": false,
    "preflightRequired": true,
    "preflightDurationSeconds": 20,
    "autoVerifyAfterRecording": true,
    "warnBeforeStartIfPreflightNotPassed": true,
    "preflightFpsPassTolerance": 2.0,
    "preflightFpsWarningTolerance": 5.0,
    "preflightMinFpsRatio": 0.93,
    "preflightMinFpsRatioMultiCamera": 0.90,
    "preflightMaxDroppedFrameRatioWarning": 0.05,
    "preflightMaxDroppedFrameRatioFail": 0.15,
    "preflightIntervalStabilityPassMs": 2.0,
    "minDiskWriteBytesPerSecond": 5000000
  },
  "locomotorStandardMode": {
    "enabled": false,
    "defaultMinimumAnalysisDurationSeconds": 600,
    "defaultRecordingDurationSeconds": 660,
    "recordLongerThanAnalysisDuration": true,
    "preferredFps": 30,
    "useMeasuredFpsForFinalReport": true,
    "requireExactThirtyFps": false,
    "requireExact18000Frames": false,
    "recommendedCropMethod": "frame_count_based",
    "autoVerifyAfterRecording": true
  },
  "locomotorStandardVerification": {
    "minimumDurationSeconds": 600,
    "preferredRecordingDurationSeconds": 660,
    "fpsPassMin": 28.5,
    "fpsPassMax": 31.0,
    "fpsWarningMin": 27.0,
    "fpsWarningMax": 32.0,
    "startSyncPassSeconds": 0.5,
    "startSyncFailSeconds": 3.0,
    "stopSyncPassSeconds": 0.5,
    "stopSyncFailSeconds": 3.0,
    "durationDifferencePassSeconds": 1.0,
    "durationDifferenceWarningSeconds": 3.0,
    "frameDifferencePassPercent": 1.0,
    "frameDifferenceWarningPercent": 3.0,
    "ignoreContainerDurationMismatchIfFrameCountsMatch": true,
    "containerDurationMismatchAsWarningOnly": true,
    "metadataProbeFrameFailTolerance": 5
  },
  "verificationProfiles": {},
  "verification": {
    "enabled": true,
    "scanExtensions": [".mp4"],
    "recursiveScan": true,
    "useFfprobe": true,
    "ffprobePath": "runtime/ffmpeg/ffprobe.exe",
    "fpsWarningTolerance": 1.5,
    "fpsFailTolerance": 3.0,
    "durationWarningToleranceSeconds": 1.5,
    "durationFailToleranceSeconds": 10.0,
    "frameWarningTolerance": 5,
    "frameFailTolerance": 60,
    "autoVerifyAfterScan": false,
    "allowReportExport": true
  },
  "security": {
    "disableAntivirusBypass": true,
    "requireAntivirusExclusion": false,
    "hiddenRecordingAllowed": false,
    "runAtStartup": false,
    "installBackgroundService": false,
    "installScheduledTask": false,
    "telemetryEnabled": false,
    "networkRequired": false,
    "autoDownloadExecutables": false,
    "manualUpdateOnly": true,
    "cameraAccessOnlyAfterUserAction": true,
    "recordingOnlyAfterUserAction": true,
    "releaseCameraOnExit": true
  }
}
