<UserControl x:Class="MultiCamApp.Ui.HeaderBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="72" MaxHeight="80">
    <Border Background="{StaticResource HeaderBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrushMain}" BorderThickness="0,0,0,1"
            Padding="16,10">
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="160"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image x:Name="LogoImage" Width="40" Height="40" Margin="0,0,12,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock x:Name="AppTitleText" Style="{StaticResource AppTitleText}"
                               VerticalAlignment="Center" Text="MultiCamApp"/>
                    <TextBlock x:Name="VersionText" Style="{StaticResource HeaderVersionText}"
                               Margin="10,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <TextBlock x:Name="SubtitleText" Grid.Column="1" Style="{StaticResource HeaderSubtitleText}"
                       Margin="16,0,12,0" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="LangLabel" Style="{StaticResource BodyText}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="LanguageBox" Style="{StaticResource InputComboBoxStyle}"
                          MinWidth="110" VerticalAlignment="Center"
                          SelectionChanged="LanguageBox_SelectionChanged">
                    <ComboBoxItem Content="English" Tag="en"/>
                    <ComboBoxItem Content="日本語" Tag="ja"/>
                </ComboBox>
                <Button x:Name="AboutButton" Style="{StaticResource HeaderAboutButtonStyle}"
                        Click="AboutButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
